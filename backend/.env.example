# Database (required)
DATABASE_URL="postgresql://user:password@localhost:5432/edschool"

# JWT (required in production - use a strong random secret)
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# CORS - comma-separated origins for production (e.g. https://yourdomain.com)
# Leave unset in dev to allow all origins
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Web Push (optional - run: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY="BPxxx..."
# VAPID_PRIVATE_KEY="xxx..."
# VAPID_SUBJECT="mailto:support@edumapping.com"

# Google Maps (frontend env var — set in frontend/.env)
# VITE_GOOGLE_MAPS_KEY="AIza..."
